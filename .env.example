# Zkopíruj tento soubor jako ".env" a doplň hodnoty.
# Soubor .env se NIKDY necommituje (je v .gitignore).

# Heslo pro přihlášení do kokpitu (lokální MVP)
ADMIN_PASSWORD=zmen-me

# Tajný klíč pro session (vygeneruj náhodný řetězec)
SECRET_KEY=zmen-me-na-nahodny-retezec

# Clockify – read-only API klíč (Profile Settings → API)
CLOCKIFY_API_KEY=
# Volitelné: když máš víc workspaců, doplň ID konkrétního
CLOCKIFY_WORKSPACE_ID=

# Databáze – lokálně nech prázdné (použije se SQLite).
# Na Railway nastav DATABASE_URL na PostgreSQL.
DATABASE_URL=

# Pro pozdější konverzační vrstvu
ANTHROPIC_API_KEY=
